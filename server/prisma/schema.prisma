// Schema de CCM — canon = work-agent/backend/04-modelo-de-datos.md
// Traducción 1:1 del dominio (src/data/types.ts) a Postgres.
// NOTA: el índice único parcial de AdCampaign ("una activa por slot") NO se expresa
// en Prisma; se crea por SQL crudo en una migración (ver más abajo y doc 04 §1).

generator client {
  provider      = "prisma-client-js"
  // native = plataforma de build; debian-openssl-3.0.x = runtime en Railway (node:22-slim).
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────────────────────

enum EventType {
  principal
  camino
  capacitacion
}

enum RegistrationStatus {
  confirmada
  cancelada
}

enum PlanDay {
  sabado
  domingo
  combo
}

enum PlanKind {
  general
  vip
}

enum OrderStatus {
  iniciada
  redirigida_mp
  confirmada
  cancelada
}

enum SponsorLevel {
  Principal
  Oro
  Plata
}

enum AdSlot {
  S1
  S2
  S3
  S4
  S6 // S5 no existe en el dominio: hueco intencional, no agregar
}

enum MembershipTier {
  free
  socio
}

enum ApplicationStatus {
  preinscripta
  aceptada
  rechazada
}

enum CampaignStatus {
  pendiente_pago // orden creada, esperando confirmación de MP
  activa
  expirada
  rechazada
}

// Rol del panel admin (canon 9).
//   OWNER   — todo, incluida la gestión del equipo.
//   EDITOR  — operación del evento: eventos, convocatorias, postulaciones (ve PII), catálogo.
//   CONTENT — contenido editorial: notas, galerías, banners, beneficios. NO ve PII.
//   STAFF   — personal de puerta (solo escanea QR).
//   VIEWER  — solo lectura / reporte a sponsors.
// ⚠️ STAFF y VIEWER están definidos pero NO habilitados para entrar: todavía no existe la
// pantalla que justifica cada uno (acreditación por QR; reporte a sponsors scopeado en el
// server). Se habilitan cuando exista esa superficie — ver adminRoles.ts, LOGIN_ENABLED_ROLES.
enum AdminRole {
  OWNER
  EDITOR
  CONTENT
  STAFF
  VIEWER
}

// Estado de una persona del equipo. `invited` ya puede entrar (el email de invitación la manda
// al login normal); pasa a `active` en su primer ingreso. `disabled` la saca al instante.
enum AdminUserStatus {
  invited
  active
  disabled
}

// Tipo de recurso que paga una fila Payment (canon 7).
enum PaymentKind {
  ticket_order
  membership
  ad_campaign
}

// Estado del cobro en MP (independiente del estado de negocio del recurso).
enum PaymentStatus {
  pending
  approved
  rejected
  refunded
  // Un `pending` que superó UMBRAL_VENCIMIENTO_PENDIENTE_MS (mpCheckoutService.ts) SIN que MP
  // llegara a reportar un pago concreto (mpPaymentId sigue null) NI tener un pago vivo asociado
  // en MP. Distinto de `rejected`: acá nadie rechazó nada, el comprador simplemente no volvió. Lo
  // vence el propio intento de compra siguiente (perezoso, sin job de fondo) para liberar el
  // índice único parcial PaymentItem(kind,resourceId) WHERE "closedAt" IS NULL (migración
  // 9_ticket_multi_order_payment).
  expired
}

enum ProfileFieldKey {
  firstName
  lastName
  email
  profession
  phone
  dni
  city
  instagram
}

// ─────────────────────────────────────────────────────────
//  IDENTIDAD / PERFIL
// ─────────────────────────────────────────────────────────

// Device = única entidad raíz del usuario (canon 6). No hay tabla DeviceProfile:
// el tipo TS DeviceProfile se serializa desde Device + ProfileField en el repo.
model Device {
  id        String   @id @default(cuid())
  publicId  String   @unique
  createdAt DateTime @default(now())

  consentTerms    DateTime?
  consentNews     DateTime?
  consentSponsors DateTime?

  fields        ProfileField[]
  registrations Registration[]
  orders        TicketOrder[]
  membership    Membership?
  tickets       Ticket[]
  favorites     PhotoFavorite[]
  downloads     PhotoDownload[]
  applications  Application[]
  analytics     AnalyticsEvent[]
  payments      Payment[]

  personId String?
  person   Person? @relation(fields: [personId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([personId])
}

// ─────────────────────────────────────────────────────────
//  PERSONAS (CRM)
// ─────────────────────────────────────────────────────────

/**
 * Ancla de identidad. NO copia datos personales: solo guarda las claves con las que se
 * unifica (email, dni normalizados). Los datos siguen en ProfileField —con su procedencia—
 * y en Application.data. Copiarlos acá destruiría el "cuándo y en qué acción se capturó",
 * que es lo que hace valiosa a la base propia.
 */
model Person {
  id        String   @id @default(cuid())
  email     String?  @unique
  dni       String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  devices      Device[]
  applications Application[]

  @@index([createdAt])
}

// Captura progresiva de PII (canon 4). Un valor por (device, key).
model ProfileField {
  id         String          @id @default(cuid())
  deviceId   String
  key        ProfileFieldKey
  value      String
  source     String
  capturedAt DateTime        @default(now())

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, key])
  @@index([key, value])
}

// ─────────────────────────────────────────────────────────
//  EVENTOS, BLOQUES E INSCRIPCIONES
// ─────────────────────────────────────────────────────────

model Event {
  id          String    @id // ej. "ev-principal-2026"
  slug        String    @unique
  type        EventType
  title       String
  subtitle    String?
  dateLabel   String
  startDate   DateTime
  timeLabel   String?
  venue       String
  address     String
  mapsUrl     String
  description String    @db.Text
  cover       String
  price       Int?
  past        Boolean   @default(false)
  socioOnly   Boolean   @default(false) // gate a nivel EVENTO (canon 17); el bloque lo hereda
  // Un evento nace BORRADOR: se puede cargar de a poco sin que el público lo vea a medio hacer.
  // Publicar es un acto aparte y explícito. Antes cada alta salía a la app en el mismo instante
  // en que se apretaba "Crear", sin vuelta atrás — no se podía despublicar y borrar se traba con
  // la primera inscripción.
  // ⚠️ La migración pone DEFAULT true para que los eventos que YA existían sigan publicados, y
  // recién después baja el default a false. Sin ese orden, todo lo que está al aire desaparecía.
  published   Boolean   @default(false)

  blocks        EventBlock[]
  registrations Registration[]
  sponsors      EventSponsor[]
  convocatorias Convocatoria[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, startDate])
  @@index([past])
  // El público sólo ve lo publicado: el índice acompaña ese filtro, que corre en cada visita.
  @@index([published])
}

// EventItem.sponsorIds[] → tabla puente.
model EventSponsor {
  eventId   String
  sponsorId String

  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sponsor Sponsor @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

  @@id([eventId, sponsorId])
}

model EventBlock {
  id          String   @id
  eventId     String
  title       String
  kind        String
  day         String
  start       String
  end         String
  room        String
  capacity    Int
  seedTaken   Int      @default(0) // baseline del cupo; real = seedTaken + count(confirmadas)
  speakers    String[]
  description String?  @db.Text

  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrations Registration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId])
}

model Registration {
  id       String             @id // "reg_..."
  deviceId String
  eventId  String
  blockId  String?
  status   RegistrationStatus @default(confirmada)
  ts       DateTime           @default(now())

  device Device      @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  event  Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  block  EventBlock? @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@unique([deviceId, eventId, blockId])
  @@index([blockId, status])
  @@index([eventId, status])
}

// ─────────────────────────────────────────────────────────
//  ENTRADAS, PLANES Y ÓRDENES
// ─────────────────────────────────────────────────────────

model TicketPlan {
  id            String   @id // PlanId
  name          String
  tagline       String
  price         Int? // null = precio pendiente 🔶
  serviceCharge Int      @default(0)
  mpLink        String?
  perks         String[]
  featured      Boolean  @default(false)
  day           PlanDay
  kind          PlanKind
  preventa      Boolean  @default(false)

  orders TicketOrder[]

  updatedAt DateTime @updatedAt
}

model TicketOrder {
  id         String      @id // "ord_..."
  deviceId   String?
  planId     String
  status     OrderStatus @default(iniciada)
  qty        Int         @default(1)
  total      Int // congelado al crear = (price + serviceCharge) * qty
  buyerName  String?
  buyerEmail String?
  ts         DateTime    @default(now())

  /// AdminUser.id de quien REGALÓ esta entrada. null = venta real.
  /// Sin FK a propósito, mismo criterio que AdminUser.invitedBy: el dato tiene que sobrevivir
  /// a que esa persona se vaya del equipo.
  /// NO es decorativo: `total === 0` NO alcanza para reconocer una cortesía, porque un plan con
  /// `price: null` produce órdenes REALES de total 0. Sin este campo el Dashboard cuenta los
  /// regalos de Gastón como ventas (statsService).
  grantedById String?

  // La plomería MP vive en Payment (kind='ticket_order'), no acá (canon 7).
  device  Device?    @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  plan    TicketPlan @relation(fields: [planId], references: [id])
  tickets Ticket[]

  @@index([status, ts])
  @@index([planId])
  @@index([buyerEmail])
  @@index([grantedById])
}

// Acreditación: estado de uso del QR en puerta. El QR es un JWT firmado con
// ACCREDITATION_TOKEN_SECRET; esta fila guarda el jti + check-in (canon 11). Doc 13.
model Ticket {
  id          String    @id @default(cuid())
  deviceId    String
  orderId     String? // null si entrada GRATIS (Registration confirmada, sin pago)
  jornada     String
  qrToken     String    @unique // jti del JWT
  checkedIn   Boolean   @default(false)
  checkedInAt DateTime?
  createdAt   DateTime  @default(now())

  device Device       @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  order  TicketOrder? @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([deviceId, jornada]) // una entrada por jornada
  @@index([checkedIn])
}

// ─────────────────────────────────────────────────────────
//  CATÁLOGO (EXPOSITORES)
// ─────────────────────────────────────────────────────────

model CatalogProfile {
  id             String   @id // "cat-..."
  slug           String   @unique
  name           String
  role           String
  kind           String   @default("participante") // participante | expositor (feedback Gastón: distinto cupo de imágenes + "cuenta proyectos")
  platform       String
  city           String
  bio            String   @db.Text
  projects       String?  @db.Text // "cuenta proyectos" del expositor (narrativa; solo expositores)
  photo          String
  instagram      String?
  whatsapp       String? // contacto directo (wa.me/… o número) — "si quiere se contacta" (Gastón)
  verified       Boolean  @default(false)
  participatesIn String[]

  portfolio PortfolioPiece[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([platform])
}

model PortfolioPiece {
  id        String  @id @default(cuid())
  profileId String
  image     String
  title     String
  caption   String?
  price     Int? // precio del cuadro/prenda (opcional) — "algunas tendrán el precio" (Gastón)
  order     Int     @default(0)

  profile CatalogProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, order])
}

// ─────────────────────────────────────────────────────────
//  FOTOS (GALERÍAS, FAVORITOS, DESCARGAS)
// ─────────────────────────────────────────────────────────

model Gallery {
  id         String @id // "gal-..."
  slug       String @unique
  title      String
  eventLabel String
  date       String
  cover      String
  sponsorId  String

  // onDelete: Restrict (canon 16): no se borra un Sponsor con galerías.
  sponsor Sponsor @relation(fields: [sponsorId], references: [id], onDelete: Restrict)
  photos  Photo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sponsorId])
}

model Photo {
  id        String @id // "ph-..."
  galleryId String
  src       String
  alt       String
  order     Int    @default(0)

  gallery   Gallery         @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  favorites PhotoFavorite[]
  downloads PhotoDownload[]

  @@index([galleryId, order])
}

model PhotoFavorite {
  deviceId String
  photoId  String
  ts       DateTime @default(now())

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  photo  Photo  @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@id([deviceId, photoId])
}

model PhotoDownload {
  id        String   @id @default(cuid())
  deviceId  String
  photoId   String
  galleryId String
  sponsorId String // desnormalizado: a qué sponsor le suma esta descarga
  ts        DateTime @default(now())

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  photo  Photo  @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@index([sponsorId, ts])
  @@index([galleryId])
}

// ─────────────────────────────────────────────────────────
//  SPONSORS Y PUBLICIDAD
// ─────────────────────────────────────────────────────────

model Sponsor {
  id        String       @id // "sp-..."
  name      String
  industry  String
  level     SponsorLevel
  exclusive Boolean      @default(false) // exclusividad de rubro (D20)
  tagline   String
  banner    String? // arte horizontal 3:1 para el SponsorCarousel (URL). Sin él, la UI cae a un lockup de marca.

  creatives SponsorCreative[]
  galleries Gallery[]
  events    EventSponsor[]
  contents  ContentItem[]     @relation("ContentSponsor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([level])
  @@index([industry])
}

model SponsorCreative {
  id        String  @id @default(cuid())
  sponsorId String
  slot      AdSlot
  headline  String
  sub       String?
  cta       String?
  order     Int     @default(0)

  sponsor Sponsor @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

  @@index([slot, sponsorId])
}

// Publicidad autogestionada (self-serve). Vigencia: startsAt/expiresAt + status (canon 8).
// "Una activa por slot" se garantiza con un índice único PARCIAL en SQL crudo (no expresable
// en el datamodel). Creado en la migración prisma/migrations/1_one_active_per_slot.
model AdCampaign {
  id        String         @id // "camp_..."
  slot      AdSlot
  brand     String
  headline  String
  cta       String?
  tagline   String?
  status    CampaignStatus @default(pendiente_pago)

  hours     Int // lo comprado (trazabilidad/factura)
  startsAt  DateTime? // se setea al confirmar el pago
  expiresAt DateTime? // = startsAt + hours

  total Int
  ts    DateTime @default(now())

  @@index([slot, status, expiresAt])
}

// ─────────────────────────────────────────────────────────
//  CONTENIDO (VIDEOS)
// ─────────────────────────────────────────────────────────

model ContentItem {
  id          String   @id // "ct-..."
  type        String   @default("video")
  title       String
  description String   @db.Text
  youtubeId   String
  duration    String?
  platform    String?
  sponsorId   String?
  publishedAt DateTime
  socioOnly   Boolean  @default(false)

  sponsor Sponsor? @relation("ContentSponsor", fields: [sponsorId], references: [id], onDelete: SetNull)

  @@index([publishedAt])
  @@index([socioOnly])
}

// ─────────────────────────────────────────────────────────
//  NOTAS / NOVEDADES (CMS editorial que sube prensa) — canon: feedback Gastón
// ─────────────────────────────────────────────────────────

// Nota editorial (noticia/entrevista). La carga prensa, se edita "como noticias" (semanal).
// Puede llevar un video embebido (Gastón: "una nota que creamos con un video o algo").
model Nota {
  id          String   @id // "nota-..."
  slug        String   @unique
  title       String
  excerpt     String // bajada / resumen para la tarjeta
  body        String   @db.Text // cuerpo (texto plano con saltos de línea)
  cover       String? // imagen de portada (URL)
  author      String? // firma (prensa)
  category    String? // moda | belleza | arte | gastronomia | turismo | tecnologia | evento
  youtubeId   String? // video embebido opcional
  published   Boolean  @default(true)
  publishedAt DateTime
  order       Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, publishedAt])
}

// ─────────────────────────────────────────────────────────
//  BANNERS GESTIONADOS (publicidad simple, la sube marketing) — canon: feedback Gastón
// ─────────────────────────────────────────────────────────

// Destino al que va el banner cuando lo tocan (el cliente da el link).
enum BannerDestination {
  whatsapp
  link
  form
}

// Banner publicitario que carga marketing: una imagen + un destino + medición de clicks.
// Distinto del AdCampaign self-serve (que una marca compra y paga): esto lo gestiona el equipo.
// "Los principales son fijos y el resto rota" → `fixed`. Métrica = eventos banner_click/impression.
model Banner {
  id              String            @id // "bnr-..."
  slot            String // ubicación lógica: 'home' | 'eventos' | 'catalogo' | 'fotos' | 'contenido'
  brand           String // anunciante (para el reporte del admin)
  image           String // URL de la imagen (marketing pega/sube en el formato pedido)
  alt             String?
  destinationType BannerDestination @default(link)
  destinationUrl  String // wa.me/… | https://… | link a formulario
  fixed           Boolean           @default(false) // fijo (siempre visible) vs rota con los demás
  order           Int               @default(0)
  active          Boolean           @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slot, active])
}

// ─────────────────────────────────────────────────────────
//  BENEFICIOS (descuentos para registrados) — canon: feedback Gastón
// ─────────────────────────────────────────────────────────

// Beneficio para usuarios registrados (hotel, spa, gastronomía, entradas, suscripción…).
// El `code` se sirve SOLO a devices con inscripción confirmada (gate en benefitService).
// Low-stakes por decisión de negocio: sin límite de usos ni anti-fraude (Gastón).
model Benefit {
  id            String    @id // "ben-..."
  partner       String // "Hotel Quinto Centenario"
  category      String // hotel | spa | gastronomia | entradas | suscripcion | otro
  title         String // "25% en alojamiento"
  description   String    @db.Text
  code          String? // código de descuento (revelado solo a registrados)
  discountLabel String? // "25% OFF" / "2x1"
  url           String? // dónde canjear (link / wa.me / formulario)
  logo          String?
  validUntil    DateTime?
  order         Int       @default(0)
  active        Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, order])
}

// ─────────────────────────────────────────────────────────
//  MEMBRESÍA (SOCIO CCM)
// ─────────────────────────────────────────────────────────

model Membership {
  id        String         @id @default(cuid()) // PK propia (canon 7) para Payment.resourceId
  deviceId  String         @unique
  tier      MembershipTier @default(free)
  since     DateTime?
  paid      Int            @default(0)
  expiresAt DateTime? // 🔶 perpetua vs por-edición vs anual

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([tier])
}

// ─────────────────────────────────────────────────────────
//  PAGOS (MERCADO PAGO) — tabla polimórfica (canon 7)
// ─────────────────────────────────────────────────────────

// Un Payment es la CABECERA de un cobro: una preferencia de Mercado Pago, un monto, un estado.
// Lo que se está comprando vive en `items` (una fila PaymentItem por recurso concreto), porque
// un mismo cobro puede cubrir VARIAS órdenes: el comprador elige dos planes VIP y paga UNA vez
// el total que ve en pantalla. Antes `kind`/`resourceId` vivían acá, lo que forzaba una
// preferencia por orden — y el front, que solo podía mandar a MP un link, cobraba la primera
// orden y regalaba el resto.
//
// La protección contra doble cobro (índice único parcial) NO se debilitó: se mudó tal cual a
// PaymentItem(kind, resourceId) WHERE "closedAt" IS NULL, que es donde vive ahora la relación
// "una fila viva ↔ un recurso" que ese índice siempre asumió. Ver
// prisma/migrations/9_ticket_multi_order_payment.
model Payment {
  id       String  @id @default(cuid())
  deviceId String?

  mpPreferenceId String?
  initPoint      String? // init_point de la preferencia — se guarda para poder reusarla si se
  // pide el cobro de nuevo con un Payment `pending` existente, en vez de crear otra preferencia
  // (eso es lo que evita el doble cobro: dos preferencias vivas para la misma orden).
  mpPaymentId    String?       @unique // idempotencia del webhook
  externalRef    String?
  amount         Int // SUMA de items[].amount — lo que MP cobra. Lo calcula el server, nunca el body.
  status         PaymentStatus @default(pending)
  raw            Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  device Device?       @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  items  PaymentItem[]

  @@index([status])
  @@index([deviceId])
}

/// Una línea del cobro = UN recurso concreto. Un cobro puede cubrir varias (carrito de varios
/// planes VIP = UNA preferencia de MP). Acá vive ahora la protección contra doble cobro que
/// antes vivía en Payment(kind, resourceId).
model PaymentItem {
  id         String      @id @default(cuid())
  paymentId  String
  kind       PaymentKind
  resourceId String // TicketOrder.id | Device.id (membresía) | AdCampaign.id — sin FK formal
  amount     Int // monto de ESTA línea, calculado por el server
  titulo     String // el que ve el comprador en MP; se guarda para poder reconciliar en un incidente

  /// null = línea VIVA (el cobro está `pending`). Se sella cuando el Payment deja de estar
  /// pending. Existe SOLO para que el índice único parcial pueda vivir en esta tabla: el
  /// predicado de un índice parcial de Postgres únicamente puede mirar columnas propias.
  /// INVARIANTE: closedAt IS NULL ⟺ Payment.status = 'pending'. Se escribe EXCLUSIVAMENTE
  /// desde cerrarPago()/vencerPendientesAbandonados() (mpPaymentState.ts), nunca a mano.
  closedAt DateTime?

  /// Cuándo se entregó ESTA línea (orden confirmada / socio dado de alta / campaña activada).
  /// Hace reanudable la entrega parcial sin agregar valores al enum PaymentStatus: si el
  /// webhook entregó 1 de 2 líneas y falló, el reintento de MP saltea la ya entregada.
  deliveredAt DateTime?

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@unique([paymentId, kind, resourceId])
  @@index([kind, resourceId])
  // ⚠️ El índice ÚNICO PARCIAL (kind, resourceId) WHERE "closedAt" IS NULL NO se puede expresar
  // acá (@@unique no soporta predicado). Vive en SQL crudo en la migración
  // 9_ticket_multi_order_payment, mismo patrón que "one_active_per_slot" en AdCampaign.
}

// ─────────────────────────────────────────────────────────
//  CONVOCATORIAS Y POSTULACIONES
// ─────────────────────────────────────────────────────────

model Convocatoria {
  id       String   @id // "conv-..."
  slug     String   @unique
  title    String
  intro    String   @db.Text
  deadline DateTime
  eventId  String
  ctaLabel String? // texto del botón CTA (ej. "Quiero sumar mi universidad")
  ctaUrl   String? // destino del CTA (wa.me/… | https://… | formulario)

  event        Event               @relation(fields: [eventId], references: [id])
  fields       ConvocatoriaField[]
  logos        ConvocatoriaLogo[]
  applications Application[]

  @@index([eventId])
}

// Logos que se muestran en la convocatoria, agrupados por rubro (universidades,
// sponsors, aliados). La imagen es una URL (upload real llega con el storage).
model ConvocatoriaLogo {
  id             String  @id @default(cuid())
  convocatoriaId String
  name           String
  logoUrl        String
  url            String? // link opcional al tocar el logo
  rubro          String? // para agrupar (ej. "Universidades", "Sponsors")
  order          Int     @default(0)

  convocatoria Convocatoria @relation(fields: [convocatoriaId], references: [id], onDelete: Cascade)

  @@index([convocatoriaId, order])
}

model ConvocatoriaField {
  id             String   @id @default(cuid())
  convocatoriaId String
  key            String
  label          String
  type           String
  required       Boolean  @default(false)
  options        String[]
  placeholder    String?
  help           String?
  showIfKey      String?
  showIfEquals   String?
  order          Int      @default(0)

  convocatoria Convocatoria @relation(fields: [convocatoriaId], references: [id], onDelete: Cascade)

  @@unique([convocatoriaId, key])
  @@index([convocatoriaId, order])
}

model Application {
  id             String            @id // "app_..."
  convocatoriaId String
  deviceId       String?
  status         ApplicationStatus @default(preinscripta)
  data           Json
  fromSeed       Boolean           @default(false)
  ts             DateTime          @default(now())
  decidedAt      DateTime?
  /// EMAIL del admin que decidió. Sin FK a propósito (igual criterio que AdminUser.invitedBy):
  /// si esa persona se da de baja, la decisión que tomó no debe desaparecer ni bloquear el borrado.
  decidedBy    String?
  /// Nota INTERNA del equipo. Nunca viaja al postulante.
  decisionNote String?   @db.Text
  /// Cuándo salió el aviso. null = no se mandó (ver notifyError para saber si fue por un fallo).
  notifiedAt   DateTime?
  /// Por qué no salió, si falló. Se muestra en la ficha con opción de reintentar.
  notifyError  String?

  convocatoria Convocatoria @relation(fields: [convocatoriaId], references: [id], onDelete: Cascade)
  device       Device?      @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  personId String?
  person   Person? @relation(fields: [personId], references: [id], onDelete: SetNull)

  @@index([convocatoriaId, status])
  @@index([status, ts])
  @@index([personId])
}

// ─────────────────────────────────────────────────────────
//  ANALYTICS (ALTO VOLUMEN)
// ─────────────────────────────────────────────────────────

model AnalyticsEvent {
  id       String   @id @default(cuid())
  event    String // taxonomía canónica (doc 05)
  deviceId String?
  payload  Json?
  seed     Boolean  @default(false)
  ts       DateTime @default(now())

  device Device? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([event, ts])
  @@index([ts])
  @@index([deviceId])
}

// ─────────────────────────────────────────────────────────
//  ADMIN (ORGANIZADOR)
// ─────────────────────────────────────────────────────────

model AdminUser {
  id        String          @id @default(cuid())
  email     String          @unique
  name      String?
  role      AdminRole       @default(EDITOR) // canon 9
  status    AdminUserStatus @default(invited)
  invitedBy String? // nombre de quien lo invitó (no FK: sobrevive a que esa persona se vaya)
  invitedAt DateTime        @default(now())
  createdAt DateTime        @default(now())
  lastLogin DateTime?

  sessions   AdminSession[]
  loginCodes AdminLoginCode[]
}

// Sesión del panel. Es la AUTORIDAD: el token firmado no alcanza por sí solo, tiene que existir
// esta fila. Por eso cerrar sesión (que la borra) revoca de verdad, y no hay que esperar a que
// venza ningún token.
model AdminSession {
  id        String    @id @default(cuid())
  userId    String
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  expiresAt DateTime

  @@index([userId])
}

// Código OTP de un solo uso para entrar al panel. Se guarda HASHEADO (HMAC con pepper + userId),
// nunca en claro. El más reciente sin consumir es el que vale.
model AdminLoginCode {
  id         String    @id @default(cuid())
  userId     String
  user       AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash   String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  // Sirve a las dos consultas del login: traer el último código vivo del usuario y contar
  // los emitidos en la ventana de rate limit.
  @@index([userId, createdAt])
}

// ─────────────────────────────────────────────────────────
//  MERCADO PAGO
// ─────────────────────────────────────────────────────────

/// Conexión OAuth con Mercado Pago. Una sola fila (id "default"): CCM cobra en UNA cuenta.
model MpConnection {
  id           String   @id @default("default")
  mpUserId     String // la cuenta de MP a la que entra la plata
  accessToken  String
  refreshToken String
  publicKey    String?
  expiresAt    DateTime // vencimiento del access token
  scope        String?
  connectedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────
//  ENTRADAS DE CORTESÍA
// ─────────────────────────────────────────────────────────

/// Qué se regaló. Misma forma polimórfica que PaymentItem (kind + resourceId, sin FK formal):
/// no introduce un patrón nuevo en el schema.
enum GrantKind {
  ticket_plan // resourceId = TicketPlan.id → materializa una TicketOrder
  event //       resourceId = Event.id      → materializa una Registration
}

/// Los dos caminos por los que el invitado puede reclamar, decididos con el cliente:
/// tocando el link del mail, o entrando a la app y poniendo su email.
enum GrantClaimVia {
  link //  tocó el link con el token. Un solo paso.
  code // entró a la app, puso su email y confirmó con un código de un solo uso.
}

/// Una invitación de cortesía. Existe ANTES que el dispositivo de la persona y sobrevive sin
/// dueño hasta que alguien la reclama — por eso es una entidad propia y no una TicketOrder de $0:
/// regalar un EVENTO no produce orden ninguna, produce inscripción.
model TicketGrant {
  id         String    @id // "grant_..."
  kind       GrantKind
  resourceId String
  /// Email destino NORMALIZADO (trim + lowercase). Es la clave con la que se busca al reclamar
  /// por código, así que guardarlo crudo rompería el reclamo de quien lo tipea distinto.
  email      String
  qty        Int       @default(1) // un pase que vale por N personas, no N códigos
  message    String? // mensaje personal del organizador; se inserta en el mail

  /// AdminUser.id de quien lo regaló. Sin FK, mismo criterio que TicketOrder.grantedById.
  grantedById String
  createdAt   DateTime @default(now())

  /// Secreto del link. Se guarda en claro a propósito y NO es una credencial de sesión: es de
  /// un solo uso, se invalida al reclamar y se puede revocar. Hashearlo impediría reenviar el
  /// mismo link, que es justo lo que el organizador necesita cuando el mail no llegó.
  claimToken        String         @unique
  claimedAt         DateTime?
  claimedVia        GrantClaimVia?
  claimedByDeviceId String?

  revokedAt     DateTime?
  revokedReason String?

  /// Resultado del aviso por mail. Mismo par que Application.notifiedAt/notifyError.
  notifiedAt  DateTime?
  notifyError String?

  /// Lo que se materializó al reclamar. Es lo que hace IDEMPOTENTE el reclamo: si ya hay
  /// orden (o inscripción), reintentar no duplica el regalo.
  orderId        String?
  registrationId String?

  // Reclamar por código busca los grants vivos de un email.
  @@index([email, claimedAt])
  @@index([grantedById, createdAt])
}

/// Código de un solo uso para reclamar una cortesía ENTRANDO A LA APP (sin el link del mail).
/// Espejo exacto de AdminLoginCode pero con el email como sujeto en vez de un AdminUser: acá
/// no hay cuenta previa, justamente porque el invitado nunca abrió la app.
///
/// Por qué existe: sin este paso, "poner tu email y llevarte la entrada" es robable por quien
/// conozca el email del invitado — que en prensa y sponsors es el dato más fácil de averiguar.
/// Reusa el módulo puro server/src/lib/adminOtp.ts entero (hash con pepper, ventana, intentos).
model GrantClaimCode {
  id         String    @id @default(cuid())
  email      String // normalizado, igual que TicketGrant.email
  codeHash   String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  // Las dos consultas del reclamo: el último código vivo de ese email, y cuántos se
  // emitieron en la ventana de rate limit.
  @@index([email, createdAt])
}

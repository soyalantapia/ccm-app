{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],
    "types": ["node"],
    "outDir": "dist",
    "paths": {
      // Canon 15: el backend NO duplica tipos. Importa el dominio del front.
      // Sin baseUrl (deprecado en TS6): los paths resuelven relativo a este tsconfig.
      "@domain/types": ["../src/data/types.ts"]
    },
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true
  },
  "comment": "prisma/seed.ts se corre con tsx (importa los seed del front, resolución bundler), fuera del typecheck NodeNext del server.",
  "include": ["src/**/*.ts"]
}

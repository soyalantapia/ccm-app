# ─────────────────────────────────────────────────────────────
#  Contrato de entorno del backend de CCM (canon: docs 06 y 09)
#  Copiá a .env y completá. NUNCA commitear .env.
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=4000
# Orígenes permitidos para CORS, separados por coma (el front en GH Pages + dev).
# Ej: https://soyalantapia.github.io,http://localhost:5179
CORS_ORIGINS=http://localhost:5179

# Base de datos (Railway provee DATABASE_URL en prod)
DATABASE_URL=postgresql://user:pass@localhost:5432/ccm_dev?schema=public

# ── Auth: TRES secretos JWT SEPARADOS (canon 10) — NUNCA un único JWT_SECRET ──
# Generá cada uno distinto: openssl rand -base64 48
DEVICE_TOKEN_SECRET=
ADMIN_TOKEN_SECRET=
ACCREDITATION_TOKEN_SECRET=
# Pepper para hashear los OTP de login de organizador
OTP_PEPPER=

# Email transaccional (OTP de admin; QR por email en la rama Tikealo)
RESEND_API_KEY=
# Email del primer organizador (bootstrap del rol OWNER)
ADMIN_BOOTSTRAP_EMAIL=

# ── Mercado Pago (los 3 flujos: entradas, membresía, publicidad) ──
# 🔶 DECISIÓN ABIERTA (Gastón): cuenta/credenciales productivas. Hasta entonces, SANDBOX.
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# ── Object storage S3-compatible (R2 / DigitalOcean Spaces) — imágenes subidas ──
# 🔶 DECISIÓN ABIERTA (Alan): R2 vs Spaces.
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
# URL pública/CDN desde donde se sirven las imágenes
STORAGE_PUBLIC_URL=

# ─────────────────────────────────────────────────────────────
#  Contrato de entorno del backend de CCM (canon: docs 06 y 09)
#  Copiá a .env y completá. NUNCA commitear .env.
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=4000
# Orígenes permitidos para CORS, separados por coma (el front en GH Pages + dev).
# Ej: https://soyalantapia.github.io,http://localhost:5179
# En producción NO puede ser "*" (assertProd aborta el arranque).
CORS_ORIGINS=http://localhost:5179

# Rate limiting por IP/min (opcional; defaults 120 writes / 600 analytics). OJO: en el
# venue todos comparten la IP de la WiFi → subí estos valores el día del evento si hace falta.
RATE_LIMIT_WRITES=120
RATE_LIMIT_ANALYTICS=600

# Base de datos (Railway provee DATABASE_URL en prod)
DATABASE_URL=postgresql://user:pass@localhost:5432/ccm_dev?schema=public

# ── Auth: TRES secretos JWT SEPARADOS (canon 10) — NUNCA un único JWT_SECRET ──
# Generá cada uno distinto: openssl rand -base64 48
DEVICE_TOKEN_SECRET=
ADMIN_TOKEN_SECRET=
ACCREDITATION_TOKEN_SECRET=
# Pepper para hashear los OTP de login de organizador
OTP_PEPPER=
# Fase G (auth temporal del organizador): shared secret Bearer. El front lo manda
# en Authorization: Bearer <token>. 🔶 Reemplazar por login OTP por email (RESEND).
ADMIN_TOKEN=

# Email transaccional (OTP de admin; QR por email en la rama Tikealo)
RESEND_API_KEY=
# Email del primer organizador (bootstrap del rol OWNER)
ADMIN_BOOTSTRAP_EMAIL=

# ── Mercado Pago (los 3 flujos: entradas, membresía, publicidad) ──
# 🔶 DECISIÓN ABIERTA (Gastón): cuenta/credenciales productivas. Hasta entonces, SANDBOX.
#
# Camino REAL (OAuth): el organizador conecta SU cuenta de MP desde el panel (Configuración →
# Cobros) y CCM guarda sus tokens en la tabla MpConnection. Estas 3 son de la APLICACIÓN de MP
# (las sacás de tu panel de desarrollador), no de la cuenta del organizador. Sin ellas, la
# pantalla de Cobros no puede conectar nada y todo cobro responde 503.
MP_CLIENT_ID=
MP_CLIENT_SECRET=
# Tiene que coincidir EXACTO con la redirect URI declarada en el panel de MP, incluido el dominio.
MP_REDIRECT_URI=

# Firma de los avisos (webhook). Se configura junto con la URL del webhook en el panel de MP.
MP_WEBHOOK_SECRET=

# ⏳ Plan B, sin OAuth: token pegado a mano de UNA cuenta. Solo para probar; el camino de
# producción es el OAuth de arriba.
MP_ACCESS_TOKEN=

# ── Object storage S3-compatible (R2 / DigitalOcean Spaces) — imágenes subidas ──
# 🔶 DECISIÓN ABIERTA (Alan): R2 vs Spaces.
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
# URL pública/CDN desde donde se sirven las imágenes
STORAGE_PUBLIC_URL=
